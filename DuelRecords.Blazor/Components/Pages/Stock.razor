@page "/stock"
@using DuelRecords.Blazor.Models
@using DuelRecords.Blazor.Services
@using DuelRecords.Blazor.Components.Shared

@inject AppState State
@implements IDisposable

@{
    var totalCards = State.Cards.Sum(c => c.Qty);
    var unique = State.Cards.Count;
    var rare = State.Cards.Count(c => c.Rarity is "Ultra Rara" or "Secreta");
    var filtered = string.IsNullOrEmpty(q)
        ? State.Cards
        : State.Cards.Where(c => c.Name.ToLower().Contains(q.ToLower())).ToList();
}

<div class="page-fixed-top">
    <div class="page-head">
        <div class="page-title">
            <div class="icon-bubble"><Icon Name="box" Size="22" /></div>
            <div>
                <h1>Estoque</h1>
                <div class="sub">Acompanhe a quantidade de cada card da sua coleção.</div>
            </div>
        </div>
        <button class="btn-ghost stock-stats-toggle"
                @onclick="() => statsCollapsed = !statsCollapsed"
                title="@(statsCollapsed ? "Mostrar estatísticas" : "Ocultar estatísticas")">
            @(statsCollapsed ? "▼ Estatísticas" : "▲ Ocultar")
        </button>
    </div>

    @if (!statsCollapsed)
    {
        <div class="stock-stats-grid">
            <StatCard Label="Cards na coleção" Value="@totalCards.ToString()" Sub="cópias totais" />
            <StatCard Label="Cards únicos"     Value="@unique.ToString()"     Sub="@($"{State.Cards.Count} entradas")" />
            <StatCard Label="Raridades altas"  Value="@rare.ToString()"       Sub="Ultra & Secretas" />
        </div>
    }

    <div class="stock-search-row">
        <div class="input-wrap" style="max-width:380px;width:100%">
            <input class="input" placeholder="Buscar no estoque…"
                   value="@q" @oninput="e => q = e.Value?.ToString() ?? string.Empty"
                   style="width:100%" />
            <span class="icon"><Icon Name="search" Size="15" /></span>
        </div>
        <span class="stock-count-badge">@filtered.Count @(filtered.Count == 1 ? "card" : "cards")</span>
    </div>

    <!-- Cabeçalho da tabela fixo — fora do stock-table para sticky funcionar -->
    <div class="stock-row stock-thead">
        <span></span>
        <span>Nome</span>
        <span>Tipo</span>
        <span>Atributo</span>
        <span>Raridade</span>
        <span>Edição</span>
        <span style="text-align:right">Quantidade</span>
    </div>
</div>

<div class="page-scroll-content">
    <div class="stock-table stock-body">
        @foreach (var c in filtered)
        {
            var card = c;
            <div class="stock-row" @onclick="() => openCard = card" style="cursor:pointer">
                <div class="thumb"><CardArt Card="card" Compact="true" /></div>
                <span style="font-weight:600">@card.Name</span>
                <span style="color:var(--text-muted)">@card.Type</span>
                <span style="color:var(--text-muted)">@(card.Attribute ?? "—")</span>
                <span style="color:var(--text-muted)">@card.Rarity</span>
                <span style="color:var(--text-dim);font-family:monospace;font-size:12px">@card.Set</span>
                <span style="text-align:right"><span class="qty-pill">×@card.Qty</span></span>
            </div>
        }
    </div>
</div>

@if (openCard != null)
{
    <CardDetailModal Card="openCard" OnClose="() => openCard = null" />
}

@code {
    string q = string.Empty;
    bool statsCollapsed;
    Card? openCard;

    protected override void OnInitialized() => State.OnChange += HandleStateChange;
    public void Dispose() => State.OnChange -= HandleStateChange;
    private void HandleStateChange() => InvokeAsync(StateHasChanged);
}
