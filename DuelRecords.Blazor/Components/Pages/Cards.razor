@page "/cards"
@rendermode InteractiveServer
@using DuelRecords.Blazor.Models
@using DuelRecords.Blazor.Services
@inject ICardApiService CardApiService

<h3>Cadastro de Cards</h3>

@if (!string.IsNullOrWhiteSpace(mensagemErro))
{
    <div class="alert alert-danger">
        @mensagemErro
    </div>
}
@if (!string.IsNullOrWhiteSpace(mensagemSucesso))
{
    <div class="alert alert-success">
        @mensagemSucesso
    </div>
}

<button class="btn btn-primary mb-3" @onclick="AbrirModal">
    Cadastrar Card
</button>

<a class="btn btn-outline-success mb-3 ms-2"
       href="@CardApiService.GetExportExcelUrl()"
       target="_blank">
    Exportar Excel
</a>

@if (exibirModal)
{
    <div class="card mb-4 shadow-sm">
        <div class="card-header">
            <strong>Cadastrar novo Card</strong>
        </div>

        <div class="card-body">

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label>Nome</label>
                    <input class="form-control" @bind="novoCard.Nome" />
                </div>

                <div class="col-md-6 mb-3">
                    <label>Tipo</label>
                    <select class="form-control" @bind="novoCard.TipoCard">
                        <option value="1">Monstro Normal</option>
                        <option value="2">Monstro Efeito</option>
                        <option value="3">Magia</option>
                        <option value="4">Armadilha</option>
                    </select>
                </div>

                <div class="col-md-6 mb-3">
                    <label>Atributo</label>
                    <input class="form-control" @bind="novoCard.Atributo" />
                </div>

                <div class="col-md-6 mb-3">
                    <label>Nível</label>
                    <input class="form-control" type="number" @bind="novoCard.Nivel" />
                </div>

                <div class="col-md-4 mb-3">
                    <label>Ataque</label>
                    <input class="form-control" type="number" @bind="novoCard.Ataque" />
                </div>

                <div class="col-md-4 mb-3">
                    <label>Defesa</label>
                    <input class="form-control" type="number" @bind="novoCard.Defesa" />
                </div>

                <div class="col-md-12 mb-3">
                    <label>Descrição</label>
                    <textarea class="form-control" rows="3" @bind="novoCard.Descricao"></textarea>
                </div>
            </div>

            <button class="btn btn-success" @onclick="CadastrarCard">
                Salvar
            </button>

            <button class="btn btn-secondary ms-2" @onclick="FecharModal">
                Cancelar
            </button>
        </div>
    </div>
}

<div class="mb-3">
    <label>Filtrar por nome:</label>
    <input class="form-control"
           placeholder="Digite o nome do card"
           @bind="filtroNome"
           @bind:event="oninput" />
</div>

@if (isLoading)
{
    <p>Carregando cards...</p>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Nome</th>
            <th>Tipo</th>
            <th>Atributo</th>
            <th>Nível</th>
            <th>Ataque</th>
            <th>Defesa</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var card in CardsFiltrados)
        {
            <tr>
                <td>@card.Id</td>
                <td>@card.Nome</td>
                <td>@card.TipoCard</td>
                <td>@card.Atributo</td>
                <td>@card.Nivel</td>
                <td>@card.Ataque</td>
                <td>@card.Defesa</td>
            </tr>
        }
    </tbody>
</table>

@code {

    private bool isLoading = false;

    private string mensagemErro = string.Empty;

    private string mensagemSucesso = string.Empty;

    private List<CardViewModel> cards = new();

    private CreateCardViewModel novoCard = new();

    private string filtroNome = string.Empty;

    private bool exibirModal = false;

    private IEnumerable<CardViewModel> CardsFiltrados =>
        string.IsNullOrWhiteSpace(filtroNome)
            ? cards
            : cards.Where(c => c.Nome.Contains(filtroNome, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await CarregarCards();
    }

    private async Task CarregarCards()
    {
        try
        {
            isLoading = true;
            mensagemErro = string.Empty;

            cards = await CardApiService.GetCardsAsync();
        }
        catch
        {
            mensagemErro = "Não foi possivel carregar os cards. Verifique se a API está rodando e se a Url está Correta.";
        }
        finally
        {
            isLoading = false;
        }
    }


    private void AbrirModal()
    {
        exibirModal = true;
    }

    private void FecharModal()
    {
        exibirModal = false;
    }

    private async Task CadastrarCard()
    {
        try
        {
            mensagemErro = string.Empty;
            mensagemSucesso = string.Empty;

            var sucesso = await CardApiService.CreateCardAsync(novoCard);

            if (sucesso)
            {
                mensagemSucesso = "Card cadastrado com sucesso.";

                novoCard = new CreateCardViewModel();

                FecharModal();

                await CarregarCards();
            }
            else
            {
                mensagemErro = "Não foi possível cadastrar o card. Verifique os dados informados.";
            }
        }
        catch
        {
            mensagemErro = "Erro ao cadastrar card. Verifique se a API está rodando.";
        }
    }

}
