@page "/booster/{DeckId}"

@using DuelRecords.Blazor.Models
@using DuelRecords.Blazor.Services
@using DuelRecords.Blazor.Components.Shared

@inject AppState State
@inject NavigationManager Nav

@implements IDisposable

@code {
    [Parameter] public string DeckId { get; set; } = "";

    Deck? deck;
    string stage = "intro";
    List<Card> picks = new();

    static readonly string[] Banners = new[]
    {
        "linear-gradient(135deg, #1e0b4d 0%, #5b21b6 50%, #4c1d95 100%)",
        "linear-gradient(135deg, #3a0e08 0%, #dc2626 50%, #7c2d12 100%)",
        "linear-gradient(135deg, #020617 0%, #1e3a8a 50%, #0c0a09 100%)",
        "linear-gradient(135deg, #1a0a3c 0%, #fde68a 50%, #a78bfa 100%)",
        "linear-gradient(135deg, #082f49 0%, #22d3ee 50%, #0e7490 100%)",
        "linear-gradient(135deg, #052e16 0%, #16a34a 50%, #14532d 100%)",
        "linear-gradient(135deg, #450a0a 0%, #dc2626 50%, #7f1d1d 100%)"
    };

    string PackGradient =>
        Banners[Math.Abs(DeckId.GetHashCode()) % Banners.Length];

    static bool IsRare(string rarity) =>
        rarity is "Super Rara" or "Ultra Rara" or "Secreta";

    static string RarityClass(string rarity) =>
        rarity.ToLower().Replace(" ", "-");

    protected override void OnInitialized() => State.OnChange += HandleStateChange;
    public void Dispose() => State.OnChange -= HandleStateChange;
    private void HandleStateChange() => InvokeAsync(StateHasChanged);

    protected override void OnParametersSet()
    {
        deck = State.Decks.FirstOrDefault(d => d.Id == DeckId);
    }

    async Task OpenPack()
    {
        if (deck == null) return;
        var deckCards = deck.Cards
            .Select(x => State.GetCard(x.Id))
            .Where(c => c != null)
            .Select(c => c!)
            .ToList();
        if (deckCards.Count == 0) return;

        stage = "opening";
        StateHasChanged();

        var weights = new Dictionary<string, int>
        {
            ["Comum"] = 50, ["Rara"] = 28, ["Super Rara"] = 14, ["Ultra Rara"] = 6, ["Secreta"] = 2
        };
        var weighted = new List<Card>();
        foreach (var c in deckCards)
        {
            var w = weights.GetValueOrDefault(c.Rarity, 10);
            for (int i = 0; i < w; i++) weighted.Add(c);
        }
        var rng = new Random();
        picks = Enumerable.Range(0, 5)
            .Select(_ => weighted[rng.Next(weighted.Count)])
            .ToList();

        if (!picks.Any(c => IsRare(c.Rarity)))
        {
            var rares = deckCards.Where(c => IsRare(c.Rarity)).ToList();
            if (rares.Count > 0)
                picks[4] = rares[rng.Next(rares.Count)];
        }

        await Task.Delay(700);
        stage = "revealed";
        StateHasChanged();
    }

    void Reset() { stage = "intro"; picks.Clear(); }
    void GoBack() => Nav.NavigateTo("/decks");
}

<div class="page-head">
    <div class="page-title">
        <button class="icon-btn"
                @onclick='() => Nav.NavigateTo("/decks")'
                style="margin-right:4px">
            <Icon Name="arrowLeft" Size="16" />
        </button>
        <div class="icon-bubble"><Icon Name="pack" Size="22" /></div>
        <div>
            <h1>Abrir Pacote</h1>
            <div class="sub">5 cartas aleatórias do deck "@(deck?.Name ?? "—")".</div>
        </div>
    </div>
</div>

<div class="booster-stage">

    @if (stage == "intro")
    {
        <div class="booster-pack"
             style="background:radial-gradient(circle at 30% 30%, rgba(255,255,255,0.18), transparent 60%), @PackGradient"
             @onclick="OpenPack">
            <div class="pack-flair">
                <span>★ DUEL</span>
                <span>5 CARDS</span>
            </div>
            <div class="pack-label">@(deck?.Name.ToUpper() ?? "DECK")</div>
            <div class="pack-bottom">CLIQUE PARA ABRIR</div>
        </div>
        <div style="margin-top:30px;text-align:center;max-width:460px">
            <h3 style="font-family:Cinzel,serif;font-size:20px;margin:0 0 8px">
                Pronto para o próximo duelo?
            </h3>
            <p style="color:var(--text-muted);line-height:1.6;font-size:14px">
                5 cartas aleatórias do deck que você construiu. Boa sorte, Duelista.
            </p>
        </div>
    }
    else if (stage == "opening")
    {
        <div class="booster-pack opening"
             style="background:radial-gradient(circle at 30% 30%, rgba(255,255,255,0.18), transparent 60%), @PackGradient">
            <div class="pack-label" style="opacity:0.4">Abrindo…</div>
        </div>
    }
    else
    {
        <div class="reveal-stage">
            <div class="reveal-grid">
                @for (int i = 0; i < picks.Count; i++)
                {
                    var c = picks[i];
                    var rare = IsRare(c.Rarity);
                    var rarityClass = RarityClass(c.Rarity);
                    var delay = $"animation-delay:{i * 150}ms";
                    <div class="reveal-card @(rare ? "rare" : "")" style="@delay">
                        <div class="reveal-card-frame" style="position:relative;overflow:hidden">
                            <CardArt Card="c" />
                            @if (rare)
                            {
                                <div class="rarity-flare @rarityClass"></div>
                            }
                        </div>
                        <div class="reveal-card-meta">
                            <div class="reveal-card-name">@c.Name</div>
                            <div class="reveal-card-rarity" data-r="@c.Rarity">@c.Rarity</div>
                        </div>
                    </div>
                }
            </div>
            <div class="reveal-actions">
                <button class="btn-ghost" @onclick="GoBack">Voltar ao Álbum</button>
                <button class="btn-primary" @onclick="Reset">Abrir Outro Pacote</button>
            </div>
        </div>
    }

</div>
