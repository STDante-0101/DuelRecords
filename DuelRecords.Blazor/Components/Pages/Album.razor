@page "/"

@using Microsoft.JSInterop
@using DuelRecords.Blazor.Models
@using DuelRecords.Blazor.Services
@using DuelRecords.Blazor.Components.Shared

@inject AppState State
@inject ICardApiService CardApiService
@inject IJSRuntime JS

@implements IDisposable

<div class="page-fixed-top">
    <div class="page-head">
        <div class="page-title">
            <div class="icon-bubble">
                <Icon Name="album" Size="22" />
            </div>

            <div>
                <h1>Álbum de Cards</h1>

                <div class="sub">
                    Visualize e gerencie sua coleção de cartas.
                </div>
            </div>
        </div>

        <button class="btn-primary" @onclick="OpenRegisterModal">
            <Icon Name="plus" Size="15" />
            Cadastrar Card
        </button>
    </div>

    <FiltersBar Filters="filters"
                FiltersChanged="OnFiltersChanged"
                Sort="sort"
                SortChanged="OnSortChanged"
                OnClear="ClearFilters" />
</div>

<div class="page-scroll-content">
    @if (State.IsLoadingCards)
    {
        <div class="empty">
            <h3>Carregando cards...</h3>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(State.CardsError))
    {
        <div class="empty">
            <h3>Erro ao carregar cards</h3>
            <div>@State.CardsError</div>
        </div>
    }
    else
    {
        var filtered = ApplyFilters();

        var rowsPerPage = 6;
        var perPage = State.Cols * rowsPerPage;

        var totalPages = Math.Max(1, (int)Math.Ceiling((double)filtered.Count / perPage));
        var safePage = Math.Min(page, totalPages);
        var startIdx = (safePage - 1) * perPage;
        var visible = filtered.Skip(startIdx).Take(perPage).ToList();
        visibleCards = visible;

        @if (visible.Count == 0)
        {
            <div class="empty">
                <h3>Nenhum card encontrado</h3>
            </div>
        }
        else
        {
            <div class="card-grid" style="--cols:@State.Cols">
                @foreach (var c in visible)
                {
                    var card = c;

                    <CardTile @key="card.Id"
                              Card="card"
                              OnClick="() => OpenFocus(card)"
                              OnDetails="OpenCard"
                              Favorited="@State.IsFavorite(card.Id)"
                              OnFavoriteToggle="ToggleFavorite" />
                }
            </div>
        }

        <div class="pagination">
            <span class="pager-info">
                Mostrando @(filtered.Count == 0 ? 0 : startIdx + 1)
                a @Math.Min(startIdx + perPage, filtered.Count)
                de @filtered.Count cards
            </span>

            <div class="pager">
                <button class="page-btn page-nav"
                        @onclick="PreviousPage"
                        disabled="@(safePage == 1)"
                        title="Página anterior">
                    ‹
                </button>

                @for (int i = 1; i <= totalPages; i++)
                {
                    var p = i;
                    <button class="page-btn @(p == safePage ? "active" : "")"
                            @onclick="() => GoToPage(p)">
                        @p
                    </button>
                }

                <button class="page-btn page-nav"
                        @onclick="() => NextPage(totalPages)"
                        disabled="@(safePage == totalPages)"
                        title="Próxima página">
                    ›
                </button>
            </div>

            <span class="pager-info pager-info-right">
                Página @safePage de @totalPages
            </span>
        </div>
    }
</div>

@if (focusedCard != null)
{
    <div class="sc-focus-overlay" @onclick="() => focusedCard = null">
        <button class="sc-focus-close"
                @onclick="() => focusedCard = null"
                @onclick:stopPropagation="true">✕</button>

        <div class="sc-focus-stage" @onclick:stopPropagation="true">
            <div class="sc-focus-card @slideDir" @key="@animKey" style="position:relative;overflow:hidden">
                <CardArt Card="focusedCard" />
            </div>
            <div class="sc-focus-info">
                <div class="sc-archetype-row">
                    <span class="sc-format-chip">@focusedCard.Rarity.ToUpper()</span>
                    <span class="sc-archetype-chip">@focusedCard.Kind</span>
                </div>
                <h2>@focusedCard.Name</h2>
                @if (focusedCard.Type == "Monstro")
                {
                    <div class="sc-focus-stats">
                        <div><label>ATK</label><b class="numeric">@(focusedCard.Atk?.ToString() ?? "?")</b></div>
                        @if (focusedCard.Def.HasValue)
                        {
                            <div><label>DEF</label><b class="numeric">@focusedCard.Def</b></div>
                        }
                        @if (focusedCard.Level.HasValue)
                        {
                            <div><label>Nível</label><b class="numeric">@focusedCard.Level</b></div>
                        }
                    </div>
                }
                <p class="desc">@focusedCard.Description</p>
                <button class="btn-secondary"
                        style="margin-top:auto;align-self:flex-start"
                        @onclick="() => { OpenCard(focusedCard); focusedCard = null; }">
                    <Icon Name="edit" Size="14" />
                    Detalhes
                </button>
            </div>
        </div>

        @if (visibleCards.Count > 1)
        {
            <div class="sc-focus-nav-row" @onclick:stopPropagation="true">
                <button class="btn-secondary" @onclick="() => NavigateFocus(-1)">‹ Anterior</button>
                <span class="sc-focus-nav-counter">@(focusedIndex + 1) / @visibleCards.Count</span>
                <button class="btn-secondary" @onclick="() => NavigateFocus(1)">Próximo ›</button>
            </div>
        }
    </div>
}

@if (openCard != null)
{
    <CardDetailModal Card="openCard"
                     OnClose="CloseCardModal"
                     OnDelete="DeleteCardAsync"
                     OnUpdated="OnCardUpdatedAsync" />
}

@if (showRegister)
{
    <RegisterModal OnClose="OnRegisterModalClose" />
}

@code {
    private int page = 1;
    private string sort = "name-asc";
    private CardFilters filters = new();
    private Card? openCard;
    private Card? focusedCard;
    private bool showRegister;

    private List<Card> visibleCards = new();
    private int focusedIndex;
    private int animKey;
    private string slideDir = "";

    private void OpenFocus(Card card)
    {
        focusedCard = card;
        focusedIndex = visibleCards.IndexOf(card);
        slideDir = "";
        animKey++;
    }

    private void NavigateFocus(int delta)
    {
        if (visibleCards.Count == 0) return;
        slideDir = delta > 0 ? "from-right" : "from-left";
        focusedIndex = (focusedIndex + delta + visibleCards.Count) % visibleCards.Count;
        focusedCard = visibleCards[focusedIndex];
        animKey++;
    }

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += HandleStateChange;
        await State.LoadCardsFromApiAsync(CardApiService);
        await State.LoadFavoritesAsync(JS);
    }

    private async Task OnCardUpdatedAsync(Card card)
    {
        await State.LoadCardsFromApiAsync(CardApiService);
        StateHasChanged();
    }

    public void Dispose()
    {
        State.OnChange -= HandleStateChange;
    }

    private void HandleStateChange() => InvokeAsync(StateHasChanged);

    private void OpenRegisterModal()
    {
        showRegister = true;
    }

    private void OpenCard(Card card)
    {
        openCard = card;
    }

    private void CloseCardModal()
    {
        openCard = null;
    }

    private async Task DeleteCardAsync(Card card)
    {
        if (!int.TryParse(card.Id, out var cardId))
        {
            await JS.InvokeVoidAsync("alert", $"Id inválido para exclusão: {card.Id}");
            return;
        }

        var sucesso = await CardApiService.DeleteCardAsync(cardId);

        if (sucesso)
        {
            openCard = null;
            await State.LoadCardsFromApiAsync(CardApiService);
            StateHasChanged();
        }
        else
        {
            await JS.InvokeVoidAsync("alert", "Não foi possível excluir o card.");
        }
    }

    private async Task PreviousPage()
    {
        page = Math.Max(1, page - 1);
        await JS.InvokeVoidAsync("duelRecords.scrollPageToTop");
    }

    private async Task NextPage(int totalPages)
    {
        page = Math.Min(totalPages, page + 1);
        await JS.InvokeVoidAsync("duelRecords.scrollPageToTop");
    }

    private async Task GoToPage(int p)
    {
        page = p;
        await JS.InvokeVoidAsync("duelRecords.scrollPageToTop");
    }

    private void OnFiltersChanged(CardFilters f)
    {
        filters = f;
        page = 1;
        StateHasChanged();
    }

    private void OnSortChanged(string s)
    {
        sort = s;
        page = 1;
        StateHasChanged();
    }

    private void ClearFilters()
    {
        filters = new();
        sort = "name-asc";
        page = 1;
    }

    private List<Card> ApplyFilters()
    {
        var arr = State.Cards
            .Where(c =>
            {
                if (!string.IsNullOrEmpty(filters.Q) &&
                    !c.Name.ToLower().Contains(filters.Q.ToLower()))
                {
                    return false;
                }

                if (!string.IsNullOrEmpty(filters.Type) && c.Type != filters.Type)
                {
                    return false;
                }

                if (!string.IsNullOrEmpty(filters.Attribute) && c.Attribute != filters.Attribute)
                {
                    return false;
                }

                if (!string.IsNullOrEmpty(filters.Level) && c.Level?.ToString() != filters.Level)
                {
                    return false;
                }

                if (!string.IsNullOrEmpty(filters.Kind) && c.Kind != filters.Kind)
                {
                    return false;
                }

                if (filters.OnlyFavorites && !State.IsFavorite(c.Id))
                {
                    return false;
                }

                return true;
            })
            .ToList();

        return sort switch
        {
            "name-asc" => arr.OrderBy(c => c.Name).ToList(),
            "name-desc" => arr.OrderByDescending(c => c.Name).ToList(),
            "atk-desc" => arr.OrderByDescending(c => c.Atk ?? 0).ToList(),
            "atk-asc" => arr.OrderBy(c => c.Atk ?? 0).ToList(),
            "qty-desc" => arr.OrderByDescending(c => c.Qty).ToList(),
            "rarity" => arr.OrderByDescending(c => CardCatalog.RarityRank(c.Rarity)).ToList(),
            _ => arr
        };
    }

    private async Task ToggleFavorite(Card card)
    {
        try
        {
            await State.ToggleFavoriteAsync(JS, card.Id);
        }
        catch { }
    }

    private async Task OnRegisterModalClose()
    {
        showRegister = false;
        await State.LoadCardsFromApiAsync(CardApiService);
    }
}