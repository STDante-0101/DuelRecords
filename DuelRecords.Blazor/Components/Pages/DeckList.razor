@page "/decks"

@using DuelRecords.Blazor.Models
@using DuelRecords.Blazor.Services
@using DuelRecords.Blazor.Components.Shared
@using Microsoft.JSInterop

@inject AppState State
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IDeckApiService DeckApiService
@inject ICardApiService CardApiService
@inject IDeckPrefsApiService DeckPrefsApiService

@implements IDisposable

@if (showCustomize && customizeDeck != null)
{
    <DeckCustomizeModal Deck="customizeDeck"
                        DeckCards="GetDistinctDeckCards(customizeDeck)"
                        OnClose="() => showCustomize = false"
                        OnSaved="HandleCustomizeSaved" />
}

<div class="decks-page">

    <div class="page-head">
        <div class="page-title">
            <div class="icon-bubble">
                <Icon Name="sword" Size="22" />
            </div>
            <div>
                <h1>Meus Decks</h1>
                <div class="sub">
                    @State.Decks.Count
                    @(State.Decks.Count == 1 ? " deck construído" : " decks construídos")
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(prefsLoadError))
    {
        <div style="font-size:14px;color:var(--crimson);padding:8px 16px;background:rgba(239,68,68,0.1);border-radius:6px;margin:8px 16px;word-break:break-all">@prefsLoadError</div>
    }

    @if (State.Decks.Count > 0)
    {
        <div class="decks-toolbar">
            <div class="dt-row-1">
                <div class="dt-search">
                    <span class="icon">⌕</span>
                    <input class="input"
                           placeholder="Buscar deck por nome ou tag..."
                           @bind="search"
                           @bind:event="oninput" />
                </div>
                <select class="select dt-sort" @bind="sort">
                    <option value="updated">Mais recente</option>
                    <option value="name">Nome (A-Z)</option>
                </select>
            </div>
            @if (AllTags.Any())
            {
                <div class="dt-tags-row">
                    <button class="dt-pill @(activeTag == "" ? "on" : "")" @onclick='() => activeTag = ""'>Todos</button>
                    @foreach (var tag in AllTags)
                    {
                        var t = tag;
                        <button class="dt-pill @(activeTag == t ? "on" : "")" @onclick="() => activeTag = t">@t</button>
                    }
                </div>
            }
        </div>
    }

    @if (State.Decks.Count == 0)
    {
        <div class="empty">
            <Icon Name="sword" Size="36" />
            <h3>Nenhum deck construído</h3>
            <div>Crie seu primeiro deck para começar a duelar.</div>
            <button class="btn-primary"
                    style="margin-top:16px"
                    @onclick='() => Nav.NavigateTo("/decks/new")'>
                <Icon Name="plus" Size="14" />
                Construir meu primeiro deck
            </button>
        </div>
    }
    else
    {
        <div class="my-decks-scroll">
            <div class="my-decks-grid">

                <button class="my-deck-card new"
                        @onclick='() => Nav.NavigateTo("/decks/new")'>
                    <div class="ndc-plus">+</div>
                    <div class="ndc-label">Novo Deck</div>
                    <div class="ndc-sub">Comece do zero</div>
                </button>

                @foreach (var d in FilteredDecks)
                {
                    var deck = d;

                    var allCards = deck.Cards
                        .Select(x => State.GetCard(x.Id))
                        .Where(c => c != null)
                        .Select(c => c!)
                        .ToList();

                    var featured = GetFeaturedCard(deck, allCards);
                    var fanCards = GetFanCards(deck, allCards, featured?.Id);
                    var coverBanner = GetBanner(deck);
                    var deckTags = GetDeckTags(deck.Id);

                    var mainCount = deck.Cards.Count(c => c.Section == "main");
                    var extraCount = deck.Cards.Count(c => c.Section == "extra");
                    var sideCount = deck.Cards.Count(c => c.Section == "side");
                    var legal = mainCount >= 40 && mainCount <= 60 && extraCount <= 15 && sideCount <= 15;

                    <article class="my-deck-card @(IsFavorited(deck.Id) ? "is-favorite" : "")"
                             style="@GetAttrGlowVars(deck.Id)"
                             @onclick="() => ViewDeck(deck)">

                        <div class="dc-cover" style="background:@coverBanner">
                            <div class="dc-cover-tint"></div>
                            <div class="dc-cover-glow"></div>
                            <div class="dc-cover-fan">
                                @for (int fi = 0; fi < fanCards.Count; fi++)
                                {
                                    var fc = fanCards[fi];
                                    <div class="dc-fan-mini" style="--i:@fi">
                                        <CardArt Card="fc" Compact="true" />
                                    </div>
                                }
                            </div>
                            @if (featured != null)
                            {
                                <div class="dc-featured-wrap">
                                    <div class="dc-featured-glow"></div>
                                    <div class="dc-cover-featured">
                                        <CardArt Card="featured" Compact="true" />
                                    </div>
                                </div>
                            }
                            <div class="dc-cover-shine"></div>
                            <button class="mdc-fav-btn @(IsFavorited(deck.Id) ? "favorited" : "")"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => ToggleFavorite(deck)"
                                    title="@(IsFavorited(deck.Id) ? "Remover dos favoritos" : "Favoritar")">★</button>
                        </div>

                        <div class="mdc-body">
                            <div class="mdc-head">
                                <div style="min-width:0;flex:1">
                                    @if (deckTags.Count > 0)
                                    {
                                        <div class="mdc-tags">
                                            @foreach (var tag in deckTags.Take(3))
                                            {
                                                <span class="mdc-tag">@tag</span>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="mdc-archetype">DECK</div>
                                    }
                                    <h3 class="mdc-name">@deck.Name</h3>
                                </div>
                                <button class="mdc-options"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => OpenCustomize(deck)"
                                        title="Personalizar deck">⋯</button>
                            </div>

                            <div class="mdc-chips">
                                <span class="mdc-chip @(mainCount < 40 || mainCount > 60 ? "warn" : "ok")">
                                    Main <b class="numeric">@mainCount</b>
                                </span>
                                <span class="mdc-chip">
                                    Extra <b class="numeric">@extraCount</b>
                                </span>
                                <span class="mdc-chip">
                                    Side <b class="numeric">@sideCount</b>
                                </span>
                                @if (legal)
                                {
                                    <span class="mdc-chip ok">✓ Pronto</span>
                                }
                                else
                                {
                                    <span class="mdc-chip warn">Rascunho</span>
                                }
                            </div>

                            <div class="mdc-foot">
                                <button class="mdc-btn-delete"
                                        @onclick="() => DeleteDeck(deck)"
                                        @onclick:stopPropagation="true"
                                        title="Excluir deck">
                                    <Icon Name="trash" Size="13" />
                                    Excluir
                                </button>
                                <div class="mdc-actions">
                                    <button class="btn-secondary mdc-btn"
                                            @onclick="() => EditDeck(deck)"
                                            @onclick:stopPropagation="true">
                                        <span class="mdc-btn-ic">✎</span> Editar
                                    </button>
                                    <button class="btn-primary mdc-btn"
                                            @onclick="() => ViewDeck(deck)"
                                            @onclick:stopPropagation="true">
                                        <span class="mdc-btn-ic">◉</span> Visualizar
                                    </button>
                                </div>
                            </div>
                        </div>

                    </article>
                }

            </div>
        </div>
    }

</div>

@code {

    string search = "";
    string sort = "updated";
    string activeTag = "";
    bool showCustomize;
    Deck? customizeDeck;
    Dictionary<string, DeckCoverPrefs> coverPrefsMap = new();

    IEnumerable<string> AllTags => coverPrefsMap.Values
        .SelectMany(p => p.Tags)
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(t => t);

    IEnumerable<Deck> FilteredDecks
    {
        get
        {
            var result = State.Decks.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(search))
                result = result.Where(d =>
                    d.Name.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                    GetDeckTags(d.Id).Any(t => t.Contains(search, StringComparison.OrdinalIgnoreCase)));
            if (!string.IsNullOrWhiteSpace(activeTag))
                result = result.Where(d => GetDeckTags(d.Id).Contains(activeTag, StringComparer.OrdinalIgnoreCase));
            return sort == "name"
                ? result.OrderBy(d => d.Name)
                : result;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += StateHasChanged;
        if (State.Cards.Count == 0)
            await State.LoadCardsFromApiAsync(CardApiService);
        await State.LoadDecksFromApiAsync(DeckApiService);
        await LoadCoverPrefsAsync();
    }

    public void Dispose() => State.OnChange -= StateHasChanged;

    void EditDeck(Deck d) => Nav.NavigateTo($"/decks/{d.Id}");
    void ViewDeck(Deck d) => Nav.NavigateTo($"/decks/{d.Id}/showcase");

    void OpenCustomize(Deck d)
    {
        customizeDeck = d;
        showCustomize = true;
    }

    async Task HandleCustomizeSaved()
    {
        await LoadCoverPrefsAsync();
        StateHasChanged();
    }

    string? prefsLoadError;

    async Task LoadCoverPrefsAsync()
    {
        prefsLoadError = null;
        foreach (var deck in State.Decks)
        {
            try
            {
                if (!int.TryParse(deck.Id, out var deckId)) continue;
                var p = await DeckPrefsApiService.GetPrefsAsync(deckId);
                coverPrefsMap[deck.Id] = p;
            }
            catch (Exception ex)
            {
                prefsLoadError = $"Erro ao carregar preferências: {ex.Message}";
            }
        }
    }

    async Task DeleteDeck(Deck d)
    {
        var ok = await JS.InvokeAsync<bool>("confirm", $"Excluir o deck '{d.Name}'?");
        if (!ok) return;
        await State.DeleteDeckAsync(d, DeckApiService);
        StateHasChanged();
    }

    List<Card> GetDistinctDeckCards(Deck deck) =>
        deck.Cards
            .Select(x => State.GetCard(x.Id))
            .Where(c => c != null)
            .Select(c => c!)
            .GroupBy(c => c.Id)
            .Select(g => g.First())
            .ToList();

    Card? GetFeaturedCard(Deck deck, List<Card> allCards)
    {
        if (coverPrefsMap.TryGetValue(deck.Id, out var prefs) && prefs.FeaturedCardId != null)
            return allCards.FirstOrDefault(c => c.Id == prefs.FeaturedCardId);
        return allCards.FirstOrDefault();
    }

    List<Card> GetFanCards(Deck deck, List<Card> allCards, string? featuredId)
    {
        if (coverPrefsMap.TryGetValue(deck.Id, out var prefs) && prefs.FanCardIds.Count > 0)
            return prefs.FanCardIds
                .Select(id => allCards.FirstOrDefault(c => c.Id == id))
                .Where(c => c != null).Select(c => c!)
                .Take(5).ToList();
        return allCards.Where(c => c.Id != featuredId).Take(5).ToList();
    }

    bool IsFavorited(string deckId) =>
        coverPrefsMap.TryGetValue(deckId, out var p) && p.IsFavorite;

    string GetAttrGlowVars(string deckId)
    {
        if (!coverPrefsMap.TryGetValue(deckId, out var p) || string.IsNullOrEmpty(p.GlowAttribute))
            return "";
        var rgb = AttributeColorRgb(p.GlowAttribute);
        return $"--attr-glow: rgba({rgb},0.65); --attr-glow-soft: rgba({rgb},0.12);";
    }

    static string AttributeColorRgb(string? attr) => attr switch
    {
        "Trevas" => "139,92,246",
        "Luz"    => "250,204,21",
        "Fogo"   => "239,68,68",
        "Água"   => "34,211,238",
        "Terra"  => "16,185,129",
        "Vento"  => "134,239,172",
        "Divino" => "212,166,74",
        _        => "167,139,250"
    };

    async Task ToggleFavorite(Deck d)
    {
        var prefs = coverPrefsMap.GetValueOrDefault(d.Id) ?? new DeckCoverPrefs();
        prefs.IsFavorite = !prefs.IsFavorite;
        coverPrefsMap[d.Id] = prefs;
        if (int.TryParse(d.Id, out var deckId))
            await DeckPrefsApiService.SavePrefsAsync(deckId, prefs);
        StateHasChanged();
    }

    string GetBanner(Deck deck)
    {
        if (!coverPrefsMap.TryGetValue(deck.Id, out var prefs) || !prefs.BannerIndex.HasValue)
            return DeckCovers.BannerPresets[Math.Abs(deck.Id.GetHashCode()) % DeckCovers.BannerPresets.Length].Gradient;

        var idx = prefs.BannerIndex.Value;
        if (idx < DeckCovers.BannerPresets.Length)
            return DeckCovers.BannerPresets[idx].Gradient;

        var ci = idx - DeckCovers.BannerPresets.Length;
        if (ci < prefs.CustomBannerImages.Count)
            return $"url('{prefs.CustomBannerImages[ci]}') center / cover no-repeat";

        return DeckCovers.BannerPresets[0].Gradient;
    }

    List<string> GetDeckTags(string deckId) =>
        coverPrefsMap.TryGetValue(deckId, out var prefs) ? prefs.Tags : new();
}
