@using DuelRecords.Blazor.Models

@code {
    [Parameter, EditorRequired]
    public Card Card { get; set; } = default!;

    [Parameter]
    public EventCallback OnClick { get; set; }

    [Parameter]
    public EventCallback<Card> OnDetails { get; set; }

    [Parameter]
    public bool AlwaysShowQty { get; set; }

    private async Task HandleCardClick()
    {
        if (OnClick.HasDelegate)
        {
            await OnClick.InvokeAsync();
        }
    }

    private async Task HandleDetailsClick()
    {
        if (OnDetails.HasDelegate)
        {
            await OnDetails.InvokeAsync(Card);
        }
    }
}

<div class="card-tile @(AlwaysShowQty ? "always-show-qty" : "")"
     @onclick="HandleCardClick">

    <div class="qty-chip">
        <span class="x">×</span> @Card.Qty
    </div>

    <div class="card-frame">
        <CardArt Card="Card" />
    </div>

    <div class="quick-actions">
        <button type="button"
                class="quick-btn"
                @onclick="HandleDetailsClick"
                @onclick:stopPropagation="true">

            <Icon Name="eye" Size="13" />
            Detalhes
        </button>
    </div>

    <div class="card-meta">
        <div class="card-name">
            @Card.Name
        </div>

        <div class="card-stats">
            @if (Card.Type == "Monstro")
            {
                <span class="card-level">
                    <Icon Name="star" Size="12" />
                    @Card.Level
                </span>

                <span class="card-atk">
                    ATK @Card.Atk
                </span>
            }
            else
            {
                <span class="@(Card.Type == "Magia" ? "type-tag-spell" : "type-tag-trap")">
                    @Card.Type
                </span>

                <span class="card-atk" style="font-size:11px">
                    @Card.Kind
                </span>
            }
        </div>
    </div>
</div>