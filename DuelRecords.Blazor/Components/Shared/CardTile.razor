@using DuelRecords.Blazor.Models

@code {
    [Parameter, EditorRequired]
    public Card Card { get; set; } = default!;

    [Parameter]
    public EventCallback OnClick { get; set; }

    [Parameter]
    public EventCallback<Card> OnDetails { get; set; }

    [Parameter]
    public bool AlwaysShowQty { get; set; }

    [Parameter]
    public bool Favorited { get; set; }

    [Parameter]
    public EventCallback<Card> OnFavoriteToggle { get; set; }

    private async Task HandleCardClick()
    {
        if (OnClick.HasDelegate)
            await OnClick.InvokeAsync();
    }

    private async Task HandleDetailsClick()
    {
        if (OnDetails.HasDelegate)
            await OnDetails.InvokeAsync(Card);
    }

    private async Task HandleFavClick()
    {
        if (OnFavoriteToggle.HasDelegate)
            await OnFavoriteToggle.InvokeAsync(Card);
    }
}

<div class="card-tile @(AlwaysShowQty ? "always-show-qty" : "") @(Favorited ? "favorited" : "")"
     @onclick="HandleCardClick">

    <div class="card-frame">
        <CardArt Card="Card" Compact="true" />

        <div class="qty-chip">
            <span class="x">×</span> @Card.Qty
        </div>

        @if (OnFavoriteToggle.HasDelegate)
        {
            <button type="button"
                    class="card-fav-btn @(Favorited ? "active" : "")"
                    @onclick="HandleFavClick"
                    @onclick:stopPropagation="true"
                    title="@(Favorited ? "Remover dos favoritos" : "Favoritar")">
                ★
            </button>
        }

        <!-- Unified hover panel — name + stats + Detalhes -->
        <div class="card-hover-panel">
            <div class="chp-name">@Card.Name</div>
            <div class="chp-stats">
                @if (Card.Type == "Monstro")
                {
                    <span class="chp-level">★ @Card.Level</span>
                    <span class="chp-atk">ATK @Card.Atk</span>
                }
                else
                {
                    <span class="@(Card.Type == "Magia" ? "type-tag-spell" : "type-tag-trap") chp-kind">@Card.Type</span>
                    <span class="chp-atk">@Card.Kind</span>
                }
            </div>
            <button type="button"
                    class="card-details-btn"
                    @onclick="HandleDetailsClick"
                    @onclick:stopPropagation="true">
                <Icon Name="eye" Size="11" />
                Detalhes
            </button>
        </div>
    </div>

</div>
