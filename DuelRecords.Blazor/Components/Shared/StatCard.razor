@code {
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter, EditorRequired] public string Value { get; set; } = "";
    [Parameter] public string Sub { get; set; } = "";
}
<div style="background:linear-gradient(180deg,var(--panel-2),var(--panel));border:1px solid var(--border);border-radius:14px;padding:18px 20px">
    <div style="font-size:11.5px;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.06em;font-weight:600">@Label</div>
    <div style="font-family:Cinzel,serif;font-size:32px;font-weight:700;margin-top:6px">@Value</div>
    <div style="font-size:12px;color:var(--text-dim);margin-top:2px">@Sub</div>
</div>
