@using DuelRecords.Blazor.Services
@using Microsoft.JSInterop

@inject AppState State
@inject IJSRuntime JS

<div class="tweaks-root">
    @if (open)
    {
        <div class="tweaks-panel">
            <div class="tweaks-head">
                <span>Ajustes</span>
                <button class="close-btn" @onclick="ClosePanel">
                    <Icon Name="close" Size="14" />
                </button>
            </div>

            <div class="tweaks-section">
                <div class="tweaks-label">Acento</div>

                <div class="tweaks-radio">
                    <button class="@(State.Accent == "purple" ? "on" : "")" @onclick='() => SetAccent("purple")'>Roxo</button>
                    <button class="@(State.Accent == "cyan" ? "on" : "")" @onclick='() => SetAccent("cyan")'>Ciano</button>
                    <button class="@(State.Accent == "gold" ? "on" : "")" @onclick='() => SetAccent("gold")'>Ouro</button>
                    <button class="@(State.Accent == "crimson" ? "on" : "")" @onclick='() => SetAccent("crimson")'>Carmim</button>
                </div>
            </div>

            <div class="tweaks-section">
                <div class="tweaks-label">Colunas do álbum</div>

                <select class="select" value="@State.Cols" @onchange="OnColsChange">
                    <option value="4">4 colunas</option>
                    <option value="5">5 colunas</option>
                    <option value="6">6 colunas</option>
                    <option value="7">7 colunas</option>
                    <option value="8">8 colunas</option>
                    <option value="9">9 colunas</option>
                    <option value="10">10 colunas</option>
                    <option value="11">11 colunas</option>
                    <option value="12">12 colunas</option>
                </select>
            </div>
        </div>
    }

    <button class="tweaks-fab" @onclick="TogglePanel" title="Ajustes">
        <Icon Name="sparkles" Size="16" />
    </button>
</div>

@code {
    private bool open;

    private void TogglePanel()
    {
        open = !open;
    }

    private void ClosePanel()
    {
        open = false;
    }

    private Task SetAccent(string accent)
    {
        State.SetAccent(accent);
        open = false;

        return Task.CompletedTask;
    }

    private void OnColsChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var n))
        {
            State.SetCols(n);
            open = false;
        }
    }
}